Parse metrics code: import os
import numpy as np

# Get working directory
working_dir = os.path.join(os.getcwd(), "working")

# Load experiment data
experiment_data = np.load(
    os.path.join(working_dir, "experiment_data.npy"), allow_pickle=True
).item()

# Print the best or final values for each metric for each dataset
for dataset_name, dataset_data in experiment_data.items():
    print(f"Dataset: {dataset_name}")
    print(f"Final Train Accuracy: {dataset_data['metrics']['train'][-1]:.4f}")
    print(f"Final Validation FMC: {dataset_data['metrics']['val'][-1]:.4f}")

