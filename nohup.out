Parse metrics code: import os
import numpy as np

# Get the working directory
working_dir = os.path.join(os.getcwd(), "working")

# Load the experiment data
experiment_data = np.load(
    os.path.join(working_dir, "experiment_data.npy"), allow_pickle=True
).item()


# Function to extract and print metrics
def print_metrics(data, dataset_name):
    for phase in ["train", "val"]:
        losses = data["losses"].get(phase, [])
        metrics = data["metrics"].get(phase, [])

        if losses:
            print(f"{dataset_name} - {phase.capitalize()} Loss: 
{losses[-1]:.4f}")

        if metrics:
            print(f"{dataset_name} - {phase.capitalize()} Metric: 
{metrics[-1]:.4f}")


# Print metrics for each dataset
for dataset_name, data in experiment_data.items():
    print(f"Dataset: {dataset_name}")
    print_metrics(data, dataset_name)

