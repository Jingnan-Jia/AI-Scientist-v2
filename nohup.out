Parse metrics code: import os
import numpy as np

# Setup the working directory
working_dir = os.path.join(os.getcwd(), "working")

# Load the experiment data
experiment_data = np.load(
    os.path.join(working_dir, "experiment_data.npy"), allow_pickle=True
).item()


# Helper function to get the best metric value
def get_best_metric(metrics):
    return max(metrics) if metrics else None


# Extract and print the metrics for the synthetic dataset
if "synthetic_data" in experiment_data:
    print("Synthetic Dataset Metrics:")
    # Training metrics
    if (
        "metrics" in experiment_data["synthetic_data"]
        and "train" in experiment_data["synthetic_data"]["metrics"]
    ):
        final_train_accuracy = get_best_metric(
            experiment_data["synthetic_data"]["metrics"]["train"]
        )
        print(
            f"Final Train Accuracy: {final_train_accuracy if 
final_train_accuracy is not None else 'N/A'}"
        )

    # Validation metrics
    if (
        "metrics" in experiment_data["synthetic_data"]
        and "val" in experiment_data["synthetic_data"]["metrics"]
    ):
        final_val_metric = get_best_metric(
            experiment_data["synthetic_data"]["metrics"]["val"]
        )
        print(
            f"Final Validation Metric: {final_val_metric if final_val_metric is 
not None else 'N/A'}"
        )

